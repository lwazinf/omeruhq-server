# ── Database (Supabase Postgres — SHARED with the web app) ──────────────────
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=""      # from Meta Business Manager → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=""         # permanent system user token (never expires)
WHATSAPP_WEBHOOK_VERIFY_TOKEN="" # any string you choose — paste it in Meta's webhook config too
WHATSAPP_PHONE_NUMBER="27750656348"

# ── Payments (Stitch Express) ────────────────────────────────────────────────
STITCH_CLIENT_ID=""
STITCH_CLIENT_SECRET=""
STITCH_WEBHOOK_SECRET=""      # returned by GET /admin/stitch-setup after deploy
STITCH_REDIRECT_URL=""        # e.g. https://<your-app>/payment/success

# ── Media persistence (Supabase Storage — fixes disappearing images) ────────
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_KEY=""       # service-role key, server-side only
SUPABASE_BUCKET="omeru-media" # create as a PUBLIC bucket

# ── Platform ─────────────────────────────────────────────────────────────────
PLATFORM_ADMIN_NUMBERS="27741234567"   # comma-separated wa_ids with admin access
SERVER_URL="https://<your-deployment-url>"
STOREFRONT_BASE_URL="https://omeru.io" # merchants get this link at go-live
PORT=8080
