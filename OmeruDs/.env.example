# ---------------------------------------------------------------------------
# Environment variables (ALL OPTIONAL)
#
# The app runs fully offline with built-in heuristics — no variables needed.
# Set these to power the live AI features (understanding, generation, edit
# review, interactive chat) with a local Ollama instance.
#
# Local dev:  copy this file to ".env.local" and fill in what you need.
# ---------------------------------------------------------------------------

# Base URL of your running Ollama instance.
# Default: http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Model tiers — each task picks the right size for the job.
# Run "ollama pull <model>" for any model you want to use.
#
# Recommended setup (fast machine / GPU):
#   FAST     → llama3.2:3b   (instant, good for chat & quick checks)
#   BALANCED → llama3.1:8b   (solid reasoning, structured JSON)
#   SMART    → qwen2.5:14b   (best output quality, used for full flow gen)
#
# Low-resource / CPU-only:
#   FAST     → llama3.2:1b
#   BALANCED → llama3.2:3b
#   SMART    → llama3.1:8b
#
# High-end (GPU with 24 GB+ VRAM):
#   SMART    → llama3.3:70b  or  qwen2.5:72b
# ---------------------------------------------------------------------------

# Edit review + live interactive chat  (speed matters most — local, no latency)
OLLAMA_MODEL_FAST=qwen3.5:latest

# Business brief analysis              (balanced quality / speed)
OLLAMA_MODEL_BALANCED=kimi-k2.5:cloud

# Full WhatsApp flow generation        (quality matters most)
OLLAMA_MODEL_SMART=kimi-k2:1t-cloud
